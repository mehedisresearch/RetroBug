# Copy to .env and fill in values before running.
# cp .env.example .env

# --- Required for RetroBug (agentic pipeline) and Claude baselines ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-5

# --- Required for GPT-4o zero-shot baseline only ---
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# --- LLM backend for the agentic pipeline (default: claude) ---
# Options: claude | codellama
LLM_BACKEND=claude

# --- Required only when LLM_BACKEND=codellama or running codellama baselines ---
CODELLAMA_PATH=/path/to/CodeLlama-13b-Instruct-hf
CUDA_VISIBLE_DEVICES=0
